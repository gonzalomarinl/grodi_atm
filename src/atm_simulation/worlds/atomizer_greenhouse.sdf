    <!-- Bobina de suelo con articulación de giro -->
    <model name="ground_reel">
      <pose>-6.3 -6.0 0 0 0 0</pose>
      <link name="base_link">
        <collision name="base_collision">
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>1.4 1.2 0.6</size></box></geometry>
        </collision>
        <visual name="base_visual">
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>1.4 1.2 0.6</size></box></geometry>
          <material><ambient>0.22 0.24 0.28 1</ambient><diffuse>0.22 0.24 0.28 1</diffuse></material>
        </visual>
        <visual name="support_left">
          <pose>0 0.35 1.05 0 0 0</pose>
          <geometry><box><size>0.12 0.12 1.6</size></box></geometry>
          <material><ambient>0.35 0.37 0.42 1</ambient><diffuse>0.35 0.37 0.42 1</diffuse></material>
        </visual>
        <visual name="support_right">
          <pose>0 -0.35 1.05 0 0 0</pose>
          <geometry><box><size>0.12 0.12 1.6</size></box></geometry>
          <material><ambient>0.35 0.37 0.42 1</ambient><diffuse>0.35 0.37 0.42 1</diffuse></material>
        </visual>
      </link>
      <link name="reel_link">
        <pose>0 0 1.25 0 1.5708 0</pose>
        <inertial>
          <mass>6.0</mass>
          <inertia>
            <ixx>0.15</ixx><iyy>0.15</iyy><izz>0.15</izz>
            <ixy>0.0</ixy><ixz>0.0</ixz><iyz>0.0</iyz>
          </inertia>
        </inertial>
        <collision name="reel_collision">
          <geometry><cylinder><radius>0.45</radius><length>0.42</length></cylinder></geometry>
        </collision>
        <visual name="reel_visual">
          <geometry><cylinder><radius>0.45</radius><length>0.42</length></cylinder></geometry>
          <material><ambient>0.1 0.42 0.75 1</ambient><diffuse>0.1 0.42 0.75 1</diffuse></material>
        </visual>
        <visual name="reel_core">
          <pose>0 0 0 0 0 0</pose>
          <geometry><cylinder><radius>0.16</radius><length>0.5</length></cylinder></geometry>
          <material><ambient>0.9 0.9 0.92 1</ambient><diffuse>0.9 0.9 0.92 1</diffuse></material>
        </visual>
      </link>
      <joint name="reel_joint" type="revolute">
        <parent>base_link</parent>
        <child>reel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1000</lower>
            <upper>1000</upper>
          </limit>
          <dynamics>
            <damping>0.2</damping>
          </dynamics>
        </axis>
      </joint>
    </model>

